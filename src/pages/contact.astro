---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import siteSettings from '../content/settings/site.json';

const contactItems = [
  { label: 'Email',             value: siteSettings.contactEmail, href: `mailto:${siteSettings.contactEmail}` },
  { label: 'Practice Location', value: 'Lake Mead, Nevada',       href: null },
  { label: 'Instagram',         value: '@9thislandocc',           href: siteSettings.instagramUrl },
  { label: 'Facebook',          value: '9th Island OCC',          href: siteSettings.facebookUrl },
];

const inquiryTypes = [
  { val: 'general',    label: 'General' },
  { val: 'membership', label: 'Membership' },
  { val: 'sponsor',    label: 'Sponsorship' },
  { val: 'other',      label: 'Other' },
];
---

<Layout title="Contact — 9th Island OCC" active="contact">
  <PageHero title="Get in Touch" subtitle="We'd love to hear from you" />

  <section style="background: var(--bg-alt); padding: 80px 24px;">
    <div class="two-col" style="max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 320px 1fr; gap: 80px; align-items: start;">

      <!-- Sidebar -->
      <aside>
        <div class="eyebrow" style="margin-bottom: 28px;">Contact Info</div>
        {contactItems.map((item) => (
          <div style="margin-bottom: 28px; padding-bottom: 28px; border-bottom: 1px solid var(--border);">
            <div style="font-family: var(--ff-sans); font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-light); margin-bottom: 8px;">{item.label}</div>
            {item.href ? (
              <a href={item.href} target={item.href.startsWith('http') ? '_blank' : undefined} rel="noopener" style="font-family: var(--ff-sans); font-size: 15px; color: var(--text); text-decoration: none; border-bottom: 1px solid var(--border);">{item.value}</a>
            ) : (
              <span style="font-family: var(--ff-sans); font-size: 15px; color: var(--text);">{item.value}</span>
            )}
          </div>
        ))}
        <div style="background: var(--bg); border: 1px solid var(--border); border-left: 3px solid var(--lava); padding: 20px 18px; margin-top: 8px;">
          <div style="font-family: var(--ff-serif); font-size: 15px; font-weight: 600; color: var(--text); margin-bottom: 8px;">Interested in Sponsoring?</div>
          <p style="font-family: var(--ff-sans); font-size: 13px; color: var(--text-mid); line-height: 1.7; margin: 0;">
            Select "Sponsorship" below and tell us about your business. We'd love to connect.
          </p>
        </div>
      </aside>

      <!-- Form -->
      <div>
        <div id="contact-form-wrap">
          <div class="eyebrow" style="margin-bottom: 12px;">Message Us</div>
          <h2 style="font-family: var(--ff-serif); font-size: 34px; font-weight: 700; color: var(--text); margin: 0 0 32px;">Send a Message</h2>

          <div id="inquiry-types" style="display: flex; gap: 6px; margin-bottom: 28px; flex-wrap: wrap;">
            {inquiryTypes.map((t, i) => (
              <button
                type="button"
                class="inquiry-btn"
                data-value={t.val}
                style={`background: ${i === 0 ? 'var(--text)' : 'transparent'}; color: ${i === 0 ? 'var(--bg)' : 'var(--text-mid)'}; border: 1px solid var(--border); border-radius: 2px; padding: 6px 16px; font-family: var(--ff-sans); font-size: 13px; cursor: pointer; transition: all 0.2s;`}
              >
                {t.label}
              </button>
            ))}
          </div>

          <form id="contact-form" style="display: grid; gap: 20px;">
            <input type="hidden" id="inquiryType" name="inquiryType" value="general" />

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
              <div>
                <label class="field-label" for="name">Your Name *</label>
                <input class="field-input" type="text" id="name" name="name" required />
              </div>
              <div>
                <label class="field-label" for="email">Email Address *</label>
                <input class="field-input" type="email" id="email" name="email" required />
              </div>
            </div>

            <div>
              <label class="field-label" for="subject">Subject</label>
              <input class="field-input" type="text" id="subject" name="subject" />
            </div>

            <div>
              <label class="field-label" for="message">Message *</label>
              <textarea class="field-textarea" id="message" name="message" rows="6" placeholder="Tell us about yourself and what you're interested in..." required></textarea>
            </div>

            <div id="form-message" style="display: none; padding: 16px; border-radius: 2px;"></div>

            <button id="contact-submit" type="submit" style="background: var(--lava); color: #fff; border: none; border-radius: 4px; padding: 14px 32px; font-family: var(--ff-sans); font-size: 15px; font-weight: 600; cursor: pointer; align-self: start;">
              Send Message →
            </button>
          </form>
        </div>

        <div id="contact-thanks" style="display: none; text-align: center; padding: 60px 0;">
          <div style="font-size: 52px; margin-bottom: 24px;">✉️</div>
          <h2 style="font-family: var(--ff-serif); font-size: 30px; font-weight: 700; color: var(--text); margin: 0 0 12px;">Message Sent!</h2>
          <p style="font-family: var(--ff-sans); font-size: 16px; color: var(--text-mid); line-height: 1.75; margin: 0;">
            Mahalo for reaching out — we'll get back to you shortly.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const inquiryButtons = document.querySelectorAll<HTMLButtonElement>('.inquiry-btn');
  const inquiryInput = document.getElementById('inquiryType') as HTMLInputElement | null;
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const formWrap = document.getElementById('contact-form-wrap');
  const thanks = document.getElementById('contact-thanks');
  const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null;
  const messageDiv = document.getElementById('form-message') as HTMLDivElement | null;

  inquiryButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      inquiryButtons.forEach((b) => {
        b.style.background = 'transparent';
        b.style.color = 'var(--text-mid)';
      });
      btn.style.background = 'var(--text)';
      btn.style.color = 'var(--bg)';
      if (inquiryInput) inquiryInput.value = btn.dataset.value || 'general';
    });
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form) return;

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';
    }
    if (messageDiv) messageDiv.style.display = 'none';

    try {
      const response = await fetch('https://formsubmit.co/ajax/admin@9thislandoutrigger.com', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify(data),
      });
      if (!response.ok) throw new Error('Form submission failed');

      form.reset();
      if (formWrap) formWrap.style.display = 'none';
      if (thanks) thanks.style.display = 'block';
    } catch (err) {
      if (messageDiv) {
        messageDiv.style.display = 'block';
        messageDiv.style.background = 'rgba(232,56,10,0.1)';
        messageDiv.style.color = 'var(--lava-dark)';
        messageDiv.textContent = 'Something went wrong. Please try again later.';
      }
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send Message →';
      }
    }
  });
</script>
