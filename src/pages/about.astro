---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import aboutData from '../../public/data/about.json';

const { hero, introduction, mission, activities, coaches } = aboutData;

const activityIcons = ['🚣', '🏆', '🤝', '🌊'];
---

<Layout title="About — 9th Island OCC" active="about">
  <PageHero title={hero.heading} subtitle={hero.tagline} />

  <!-- Story -->
  <section style="background: var(--bg-alt); padding: 80px 24px;">
    <div style="max-width: 720px; margin: 0 auto;">
      <div class="eyebrow" style="margin-bottom: 16px;">Our Story</div>
      <h2 style="font-family: var(--ff-serif); font-size: clamp(26px, 3vw, 38px); font-weight: 700; color: var(--text); margin: 0 0 28px;">{introduction.title}</h2>
      <p style="font-family: var(--ff-sans); font-size: 16px; color: var(--text-mid); line-height: 1.88; margin: 0 0 20px;">
        {introduction.content}
      </p>
      <p style="font-family: var(--ff-sans); font-size: 16px; color: var(--text-mid); line-height: 1.88; margin: 0;">
        The name "9th Island" is a beloved nickname for Las Vegas among the Hawaiian diaspora — so significant that Nevada is often called the 9th Hawaiian island. Our club carries that identity with pride on the water at Lake Mead.
      </p>
    </div>
  </section>

  <!-- Mission -->
  <section style="background: var(--bg); padding: 80px 24px;">
    <div class="two-col" style="max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 2fr; gap: 72px; align-items: start;">
      <div>
        <div class="eyebrow" style="margin-bottom: 16px;">Purpose</div>
        <h2 style="font-family: var(--ff-serif); font-size: clamp(26px, 3vw, 38px); font-weight: 700; color: var(--text); line-height: 1.15; margin: 0;">{mission.title}</h2>
      </div>
      <div style="display: grid; gap: 1px;">
        {mission.items.map((item, i) => (
          <div style="background: var(--bg-alt); padding: 16px 20px; display: flex; align-items: center; gap: 18px; border-left: 3px solid var(--lava);">
            <span style="font-family: var(--ff-sans); font-size: 12px; font-weight: 700; color: var(--lava); min-width: 22px; opacity: 0.7;">{(i + 1).toString().padStart(2, '0')}</span>
            <span style="font-family: var(--ff-sans); font-size: 15px; color: var(--text);">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Activities -->
  <section style="background: var(--bg-alt); padding: 80px 24px;">
    <div style="max-width: 1100px; margin: 0 auto;">
      <div class="eyebrow" style="margin-bottom: 14px;">What We Do</div>
      <h2 style="font-family: var(--ff-serif); font-size: clamp(26px, 3vw, 38px); font-weight: 700; color: var(--text); margin: 0 0 48px;">Life on the Water</h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); gap: 2px;">
        {activities.items.map((a, i) => (
          <div style="background: var(--bg); padding: 36px 28px; border-top: 2px solid var(--border);">
            <div style="font-size: 28px; margin-bottom: 18px;">{activityIcons[i % activityIcons.length]}</div>
            <h3 style="font-family: var(--ff-serif); font-size: 18px; font-weight: 600; color: var(--text); margin: 0 0 10px;">{a.name}</h3>
            <p style="font-family: var(--ff-sans); font-size: 14px; color: var(--text-mid); line-height: 1.75; margin: 0;">{a.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Coaching -->
  <section style="background: var(--bg); padding: 80px 24px;">
    <div style="max-width: 900px; margin: 0 auto; text-align: center;">
      <div class="eyebrow" style="margin-bottom: 14px;">Leadership</div>
      <h2 style="font-family: var(--ff-serif); font-size: clamp(26px, 3vw, 38px); font-weight: 700; color: var(--text); margin: 0 0 48px;">{coaches.title}</h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 24px;">
        {coaches.staff.map((c) => (
          <div style="background: var(--bg-alt); padding: 40px 32px; border: 1px solid var(--border);">
            {c.photo ? (
              <img src={c.photo} alt={c.name} style="width: 80px; height: 80px; border-radius: 50%; object-fit: cover; margin: 0 auto 20px;" />
            ) : (
              <div style="width: 80px; height: 80px; background: var(--border); border-radius: 50%; margin: 0 auto 20px; display: flex; align-items: center; justify-content: center;">
                <span style="font-family: var(--ff-sans); font-size: 10px; color: var(--text-light); text-align: center; line-height: 1.4;">Photo<br />Soon</span>
              </div>
            )}
            <h3 style="font-family: var(--ff-serif); font-size: 20px; font-weight: 600; color: var(--text); margin: 0 0 6px;">{c.name}</h3>
            <p style="font-family: var(--ff-sans); font-size: 11px; color: var(--teal); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 14px;">{c.title}</p>
            <p style="font-family: var(--ff-sans); font-size: 14px; color: var(--text-mid); line-height: 1.75; margin: 0;">{c.bio}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Sponsor prospectus -->
  <section style="background: var(--bg-alt); padding: 80px 24px; border-top: 1px solid var(--border);">
    <div style="max-width: 900px; margin: 0 auto;">
      <div class="sponsor-block" style="background: var(--bg-dark); color: #F5F0EB; padding: 48px; display: grid; grid-template-columns: 1fr auto; gap: 40px; align-items: center;">
        <div>
          <div style="font-family: var(--ff-sans); font-size: 10px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--teal-light); margin-bottom: 14px;">For Businesses</div>
          <h2 style="font-family: var(--ff-serif); font-size: 28px; font-weight: 700; margin: 0 0 16px;">Become a Club Sponsor</h2>
          <p style="font-family: var(--ff-sans); font-size: 15px; color: #9B9590; line-height: 1.75; max-width: 440px; margin: 0;">
            Partner with 9th Island OCC to reach a passionate, active community. Your brand on our jerseys, canoes, and events — connecting with the Hawaiian and paddling communities in Las Vegas.
          </p>
        </div>
        <a href="/contact" style="background: var(--lava); color: #fff; border: none; border-radius: 4px; padding: 14px 28px; font-family: var(--ff-sans); font-size: 14px; font-weight: 600; cursor: pointer; white-space: nowrap; text-decoration: none;">Get in Touch →</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background: var(--bg); padding: 64px 24px; text-align: center;">
    <div style="max-width: 560px; margin: 0 auto;">
      <h2 style="font-family: var(--ff-serif); font-size: clamp(26px, 3vw, 36px); font-weight: 700; color: var(--text); margin: 0 0 18px;">Ready to Paddle?</h2>
      <p style="font-family: var(--ff-sans); font-size: 16px; color: var(--text-mid); line-height: 1.75; margin: 0 0 32px;">
        Whether experienced or brand new, we'd love to have you join us on the water.
      </p>
      <div style="display: flex; gap: 14px; justify-content: center; flex-wrap: wrap;">
        <a href="/membership" class="btn-primary">Become a Member</a>
        <a href="/contact" class="btn-outline">Get in Touch</a>
      </div>
    </div>
  </section>
</Layout>
