---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Gallery — 9th Island OCC" active="gallery">
  <PageHero title="Gallery" subtitle="Moments from the water" />

  <!-- Instagram Feed Section -->
  <section style="background: var(--bg-alt); padding: 64px 24px;">
    <div style="max-width: 1100px; margin: 0 auto;">
      <div style="text-align: center; margin-bottom: 48px;">
        <div class="eyebrow" style="margin-bottom: 14px;">Latest from Instagram</div>
        <h2 style="font-family: var(--ff-serif); font-size: clamp(26px, 3vw, 38px); font-weight: 700; color: var(--text); margin: 0 0 16px;">@9thislandocc</h2>
        <a href="https://www.instagram.com/9thislandocc/" target="_blank" rel="noopener" style="display: inline-flex; align-items: center; gap: 8px; background: linear-gradient(135deg, #833ab4, #fd1d1d, #fcb045); color: #fff; text-decoration: none; border-radius: 4px; padding: 10px 24px; font-family: var(--ff-sans); font-size: 14px; font-weight: 600; letter-spacing: 0.02em; transition: opacity 0.2s;">
          <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          Follow @9thislandocc
        </a>
      </div>

      <!-- SociableKit Instagram Feed Embed -->
      <div style="background: var(--bg); border: 1px solid var(--border); padding: 24px; min-height: 400px;">
        <div class="sk-instagram-feed" data-embed-id="25669434"></div>
        <script src="https://widgets.sociablekit.com/instagram-feed/widget.js" defer></script>
      </div>

      <div style="text-align: center; margin-top: 48px;">
        <a href="https://www.instagram.com/9thislandocc/" target="_blank" rel="noopener" style="display: inline-block; background: var(--text); color: var(--bg); text-decoration: none; border-radius: 4px; padding: 14px 32px; font-family: var(--ff-sans); font-size: 14px; font-weight: 600; letter-spacing: 0.03em;">
          Follow on Instagram →
        </a>
      </div>
    </div>
  </section>
</Layout>
