---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';

const galleryColors = [
  '#007A7A', '#E8380A', '#1A1814', '#F4E8D0', '#C02A05', '#00A3A3',
  '#2D2820', '#F5F0EB', '#E8380A', '#007A7A', '#6B6560', '#1A1814',
  '#F4E8D0', '#C02A05', '#007A7A', '#E8380A', '#1A1814', '#00A3A3',
  '#E8380A', '#F5F0EB', '#007A7A', '#6B6560', '#C02A05', '#1A1814',
];
const galleryHeights = [
  260, 180, 220, 200, 280, 200, 180, 240,
  220, 200, 260, 180, 220, 200, 280, 180,
  240, 200, 220, 260, 180, 200, 220, 240,
];
---

<Layout title="Gallery — 9th Island OCC" active="gallery">
  <PageHero title="Gallery" subtitle="Moments from the water" />

  <section style="background: var(--bg-alt); padding: 64px 24px;">
    <div style="max-width: 1100px; margin: 0 auto;">
      <div style="background: rgba(0,122,122,0.07); border: 1px solid rgba(0,122,122,0.18); border-left: 3px solid var(--teal); padding: 16px 20px; margin-bottom: 48px; display: flex; align-items: center; gap: 14px;">
        <span style="font-size: 18px;">📸</span>
        <p style="font-family: var(--ff-sans); font-size: 14px; color: var(--text-mid); margin: 0;">
          Photos coming soon — follow us on{' '}
          <a href="https://www.instagram.com/9thislandocc/" target="_blank" rel="noopener" style="color: var(--teal); font-weight: 600;">Instagram @9thislandocc</a>{' '}
          for the latest from the water.
        </p>
      </div>

      <div style="columns: 3 220px; column-gap: 4px;">
        {galleryColors.map((color, i) => (
          <div style={`background: ${color}; margin-bottom: 4px; break-inside: avoid; height: ${galleryHeights[i]}px; display: flex; align-items: center; justify-content: center; position: relative;`}>
            <div style="display: flex; flex-direction: column; align-items: center; gap: 6px;">
              <div style="width: 28px; height: 28px; border: 1.5px solid rgba(255,255,255,0.25); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                <span style="color: rgba(255,255,255,0.3); font-size: 13px;">+</span>
              </div>
              <span style="color: rgba(255,255,255,0.2); font-family: var(--ff-sans); font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase;">Photo</span>
            </div>
          </div>
        ))}
      </div>

      <div style="text-align: center; margin-top: 48px;">
        <a href="https://www.instagram.com/9thislandocc/" target="_blank" rel="noopener" style="display: inline-block; background: var(--text); color: var(--bg); text-decoration: none; border-radius: 4px; padding: 14px 32px; font-family: var(--ff-sans); font-size: 14px; font-weight: 600; letter-spacing: 0.03em;">
          Follow on Instagram →
        </a>
      </div>
    </div>
  </section>
</Layout>
