---
import Layout from '../layouts/Layout.astro';
import siteSettings from '../content/settings/site.json';
import homepageData from '../../public/data/homepage.json';

const { whatWeOffer, sponsors } = homepageData;

const upcomingEvents = [
  { date: 'May 17', year: '2025', name: 'Nevada Desert Dash', location: 'Boulder Beach, Lake Mead', type: 'Race' },
  { date: 'Jun 14', year: '2025', name: 'Southwest Regional Championships', location: 'Parker, Arizona', type: 'Race' },
  { date: 'Nov 18', year: '2025', name: 'ADR Race', location: 'Lake Mead, Nevada', type: 'Race' },
];

const offerAccents = ['var(--lava)', 'var(--teal)', 'var(--lava)'];

const tiers = [
  { name: 'Individual',     price: '$250', period: '/year', desc: 'Full access to all practices, coaching, race eligibility, and club events.', color: 'var(--lava)',       cta: 'Join as Member',     primary: true },
  { name: 'Youth (Under 18)', price: '$25',  period: '/year', desc: 'Get your kids into outrigger racing. All practices + race participation included.', color: 'var(--teal-light)', cta: 'Youth Membership', primary: false },
];
---

<Layout title={siteSettings.siteName} description={siteSettings.description} active="home">
  <!-- Hero -->
  <section style="background: var(--bg); min-height: 90vh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 120px 24px 80px;">
    <img
      src="/logo.jpg"
      alt="9th Island OCC"
      style="width: 168px; height: 168px; border-radius: 50%; object-fit: cover; margin-bottom: 36px; box-shadow: 0 12px 48px rgba(26,24,20,0.14);"
    />
    <div style="font-family: var(--ff-sans); font-size: 11px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--teal); margin-bottom: 18px;">
      Las Vegas, Nevada
    </div>
    <h1 style="font-family: var(--ff-serif); font-size: clamp(42px, 7vw, 82px); font-weight: 700; color: var(--text); line-height: 1.04; margin: 0 0 22px; max-width: 700px;">
      9th Island<br /><em style="font-weight: 400;">Outrigger Canoe Club</em>
    </h1>
    <p style="font-family: var(--ff-sans); font-size: 18px; color: var(--text-mid); max-width: 460px; line-height: 1.75; margin: 0 0 44px;">
      Paddling Together, Building Ohana — experience the spirit of Hawaiian outrigger canoeing in the heart of the desert.
    </p>
    <div style="display: flex; gap: 14px; flex-wrap: wrap; justify-content: center;">
      <a href="/membership" class="btn-primary">Join Our Ohana</a>
      <a href="/about" class="btn-outline">Learn More</a>
    </div>
    <div style="display: flex; align-items: center; gap: 10px; margin-top: 88px; color: var(--border); font-size: 13px; letter-spacing: 0.25em;">
      <span style="width: 40px; height: 1px; background: var(--border); display: inline-block;"></span>
      <span style="color: var(--lava); opacity: 0.5;">▸▸▸</span>
      <span style="width: 40px; height: 1px; background: var(--border); display: inline-block;"></span>
    </div>
  </section>

  <!-- Stats bar -->
  <section style="background: var(--lava); padding: 28px 24px;">
    <div style="max-width: 900px; margin: 0 auto; display: grid; grid-template-columns: repeat(3, 1fr); text-align: center; gap: 16px;">
      <div style="color: #fff;">
        <div style="font-family: var(--ff-serif); font-size: 26px; font-weight: 700; margin-bottom: 3px;">2023</div>
        <div style="font-family: var(--ff-sans); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; opacity: 0.8;">Founded</div>
      </div>
      <div style="color: #fff;">
        <div style="font-family: var(--ff-serif); font-size: 26px; font-weight: 700; margin-bottom: 3px;">Lake Mead</div>
        <div style="font-family: var(--ff-sans); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; opacity: 0.8;">Practice Location</div>
      </div>
      <div style="color: #fff;">
        <div style="font-family: var(--ff-serif); font-size: 26px; font-weight: 700; margin-bottom: 3px;">Regional Races</div>
        <div style="font-family: var(--ff-sans); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; opacity: 0.8;">We Compete In</div>
      </div>
    </div>
  </section>

  <!-- Our Story -->
  <section style="background: var(--bg-alt); padding: 96px 24px;">
    <div class="two-col" style="max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center;">
      <div>
        <div class="eyebrow" style="margin-bottom: 18px;">Our Story</div>
        <h2 style="font-family: var(--ff-serif); font-size: clamp(30px, 4vw, 48px); font-weight: 700; color: var(--text); line-height: 1.12; margin: 0 0 24px;">
          Aloha in the<br /><em>Desert</em>
        </h2>
        <p style="font-family: var(--ff-sans); font-size: 16px; color: var(--text-mid); line-height: 1.85; margin: 0 0 18px;">
          9th Island OCC brings the spirit of aloha and Hawaiian outrigger canoe paddling to Las Vegas. We're a community of paddlers united by the sport of outrigger canoe racing and the cultural traditions that come with it.
        </p>
        <p style="font-family: var(--ff-sans); font-size: 16px; color: var(--text-mid); line-height: 1.85; margin: 0 0 36px;">
          "The 9th Island" is the beloved nickname for Las Vegas in the Hawaiian diaspora. We paddle with that identity and pride on the water at Lake Mead.
        </p>
        <a href="/about" style="font-family: var(--ff-sans); font-size: 14px; font-weight: 600; color: var(--lava); letter-spacing: 0.03em; text-decoration: none;">Read Our Story →</a>
      </div>
      <div style="position: relative;">
        <img
          src="/9thislandheaderwide.png"
          alt="9th Island Outrigger Canoe Club"
          style="width: 100%; border-radius: 2px; display: block;"
        />
        <div style="position: absolute; bottom: -14px; right: -14px; width: 72px; height: 72px; background: var(--lava); border-radius: 2px; opacity: 0.1; pointer-events: none;"></div>
      </div>
    </div>
  </section>

  <!-- What We Offer -->
  <section style="background: var(--bg); padding: 96px 24px;">
    <div style="max-width: 1100px; margin: 0 auto;">
      <div style="text-align: center; margin-bottom: 60px;">
        <div class="eyebrow" style="margin-bottom: 14px;">What We Offer</div>
        <h2 style="font-family: var(--ff-serif); font-size: clamp(28px, 3.5vw, 44px); font-weight: 700; color: var(--text); margin: 0;">
          More than a club —<br /><em>an ohana</em>
        </h2>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2px;">
        {whatWeOffer.items.map((item, i) => (
          <div style={`background: var(--bg-alt); padding: 48px 36px; border-top: 3px solid ${offerAccents[i % offerAccents.length]};`}>
            <h3 style="font-family: var(--ff-serif); font-size: 22px; font-weight: 600; color: var(--text); margin: 0 0 16px;">{item.title}</h3>
            <p style="font-family: var(--ff-sans); font-size: 15px; color: var(--text-mid); line-height: 1.8; margin: 0;">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Upcoming Events -->
  <section style="background: var(--bg-alt); padding: 96px 24px;">
    <div style="max-width: 1100px; margin: 0 auto;">
      <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 48px; flex-wrap: wrap; gap: 16px;">
        <div>
          <div class="eyebrow" style="margin-bottom: 14px;">On the Water</div>
          <h2 style="font-family: var(--ff-serif); font-size: clamp(28px, 3.5vw, 44px); font-weight: 700; color: var(--text); margin: 0;">Upcoming Events</h2>
        </div>
        <a href="/events" style="font-family: var(--ff-sans); font-size: 14px; font-weight: 600; color: var(--lava); letter-spacing: 0.02em; text-decoration: none;">
          Full Schedule →
        </a>
      </div>
      <div style="display: grid; gap: 1px;">
        {upcomingEvents.map((evt) => (
          <div style="background: var(--bg); padding: 24px 28px; display: grid; grid-template-columns: 88px 1fr auto; align-items: center; gap: 24px;">
            <div>
              <div style="font-family: var(--ff-serif); font-size: 24px; font-weight: 700; color: var(--lava); line-height: 1.1;">{evt.date}</div>
              <div style="font-family: var(--ff-sans); font-size: 11px; color: var(--text-light); margin-top: 2px;">{evt.year}</div>
            </div>
            <div>
              <div style="font-family: var(--ff-sans); font-size: 16px; font-weight: 600; color: var(--text); margin-bottom: 4px;">{evt.name}</div>
              <div style="font-family: var(--ff-sans); font-size: 13px; color: var(--text-mid);">{evt.location}</div>
            </div>
            <span style="font-family: var(--ff-sans); font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--teal); background: rgba(0,122,122,0.09); padding: 4px 11px; border-radius: 2px;">{evt.type}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Membership CTA -->
  <section style="background: var(--bg-dark); padding: 96px 24px;">
    <div style="max-width: 960px; margin: 0 auto;">
      <div style="text-align: center; margin-bottom: 52px;">
        <div style="font-family: var(--ff-sans); font-size: 10px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--teal-light); margin-bottom: 14px;">Ready to Paddle?</div>
        <h2 style="font-family: var(--ff-serif); font-size: clamp(28px, 3.5vw, 44px); font-weight: 700; color: #F5F0EB; margin: 0;">
          Choose Your Membership
        </h2>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 24px;">
        {tiers.map((tier) => (
          <div style={`background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.09); border-top: 4px solid ${tier.color}; padding: 40px 36px;`}>
            <div style={`font-family: var(--ff-serif); font-size: 13px; color: ${tier.color}; letter-spacing: 0.04em; margin-bottom: 10px;`}>{tier.name}</div>
            <div style="font-family: var(--ff-serif); font-size: 48px; font-weight: 700; color: #F5F0EB; line-height: 1; margin-bottom: 6px;">
              {tier.price}<span style="font-size: 18px; font-weight: 400; color: #9B9590;">{tier.period}</span>
            </div>
            <p style="font-family: var(--ff-sans); font-size: 14px; color: #9B9590; line-height: 1.75; margin: 14px 0 30px;">{tier.desc}</p>
            <a
              href="/membership"
              style={`display: inline-flex; align-items: center; justify-content: center; background: ${tier.primary ? 'var(--lava)' : 'transparent'}; color: ${tier.primary ? '#fff' : '#F5F0EB'}; border: ${tier.primary ? 'none' : '1px solid rgba(255,255,255,0.25)'}; border-radius: 4px; padding: 12px 24px; font-family: var(--ff-sans); font-size: 14px; font-weight: 600; cursor: pointer; width: 100%; text-decoration: none;`}
            >
              {tier.cta} →
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Sponsors (subtle) -->
  <section style="background: var(--bg); padding: 64px 24px; border-top: 1px solid var(--border);">
    <div style="max-width: 960px; margin: 0 auto; text-align: center;">
      <div style="font-family: var(--ff-sans); font-size: 10px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--text-light); margin-bottom: 28px;">Our Supporters</div>
      <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-bottom: 32px;">
        {sponsors.sponsors && sponsors.sponsors.length > 0 ? sponsors.sponsors.map((sp) => (
          sp.url ? (
            <a href={sp.url} target="_blank" rel="noopener" style="width: 148px; height: 58px; border: 1px solid var(--border); border-radius: 3px; display: flex; align-items: center; justify-content: center; padding: 8px;">
              <img src={sp.logo} alt={sp.name} style="max-height: 100%; max-width: 100%; object-fit: contain;" />
            </a>
          ) : (
            <div style="width: 148px; height: 58px; border: 1px solid var(--border); border-radius: 3px; display: flex; align-items: center; justify-content: center; padding: 8px;">
              <img src={sp.logo} alt={sp.name} style="max-height: 100%; max-width: 100%; object-fit: contain;" />
            </div>
          )
        )) : (
          [1, 2, 3, 4].map(() => (
            <div style="width: 148px; height: 58px; border: 1px dashed var(--border); border-radius: 3px; display: flex; align-items: center; justify-content: center;">
              <span style="font-family: var(--ff-sans); font-size: 10px; color: var(--border); letter-spacing: 0.12em; text-transform: uppercase;">Your Logo</span>
            </div>
          ))
        )}
      </div>
      <p style="font-family: var(--ff-sans); font-size: 14px; color: var(--text-mid); margin: 0 0 20px;">
        We're actively seeking sponsors who share our passion for sport, culture, and community.
      </p>
      <a href="/contact" style="font-family: var(--ff-sans); font-size: 14px; font-weight: 600; color: var(--teal); letter-spacing: 0.02em; text-decoration: none;">Become a Sponsor →</a>
    </div>
  </section>

  <!-- Social -->
  <section style="background: var(--bg-alt); padding: 64px 24px; border-top: 1px solid var(--border);">
    <div style="max-width: 600px; margin: 0 auto; text-align: center;">
      <h2 style="font-family: var(--ff-serif); font-size: 30px; font-weight: 700; color: var(--text); margin: 0 0 12px;">Follow Our Journey</h2>
      <p style="font-family: var(--ff-sans); font-size: 15px; color: var(--text-mid); margin: 0 0 32px; line-height: 1.7;">
        Latest paddling adventures, race results, and team moments on Instagram and Facebook.
      </p>
      <div style="display: flex; gap: 14px; justify-content: center; flex-wrap: wrap;">
        <a href={siteSettings.instagramUrl} target="_blank" rel="noopener" style="display: inline-flex; align-items: center; gap: 8px; background: var(--text); color: var(--bg); text-decoration: none; border-radius: 4px; padding: 12px 24px; font-family: var(--ff-sans); font-size: 14px; font-weight: 600; letter-spacing: 0.02em;">
          Instagram @9thislandocc
        </a>
        <a href={siteSettings.facebookUrl} target="_blank" rel="noopener" style="display: inline-flex; align-items: center; gap: 8px; background: transparent; color: var(--text); border: 1px solid var(--border); text-decoration: none; border-radius: 4px; padding: 12px 24px; font-family: var(--ff-sans); font-size: 14px; font-weight: 500;">
          Facebook
        </a>
      </div>
    </div>
  </section>
</Layout>
