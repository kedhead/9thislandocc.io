---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import membershipData from '../../public/data/membership.json';

const tierColors = ['var(--lava)', 'var(--teal)'];

const benefits = [
  { title: 'Training Access',  desc: 'Full access to all weekly practice sessions with coaching.' },
  { title: 'Race Eligibility', desc: 'Compete in local, regional, and national outrigger races.' },
  { title: 'Community Events', desc: 'Social gatherings, beach cleanups, and cultural celebrations.' },
  { title: 'Equipment Use',    desc: 'Access to club canoes and paddling gear during practices.' },
];

const tiers = membershipData.tiers.map((t, i) => {
  // Split price like "$250/year" into amount + period
  const match = t.price.match(/^(\$\d+)(.*)$/);
  return {
    ...t,
    priceAmount: match ? match[1] : t.price,
    pricePeriod: match ? match[2] : '',
    color: tierColors[i % tierColors.length],
  };
});
---

<Layout title="Membership — 9th Island OCC" active="membership">
  <PageHero title="Join Our Ohana" subtitle="Become part of the 9th Island family" />

  <!-- Benefits -->
  <section style="background: var(--bg-alt); padding: 80px 24px;">
    <div style="max-width: 1100px; margin: 0 auto;">
      <div style="text-align: center; margin-bottom: 56px;">
        <div class="eyebrow" style="margin-bottom: 14px;">Why Join</div>
        <h2 style="font-family: var(--ff-serif); font-size: clamp(26px, 3vw, 38px); font-weight: 700; color: var(--text); margin: 0;">Membership Benefits</h2>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 2px;">
        {benefits.map((b, i) => (
          <div style={`background: var(--bg); padding: 36px 28px; border-top: 3px solid ${i % 2 === 0 ? 'var(--lava)' : 'var(--teal)'};`}>
            <h3 style="font-family: var(--ff-serif); font-size: 18px; font-weight: 600; color: var(--text); margin: 0 0 10px;">{b.title}</h3>
            <p style="font-family: var(--ff-sans); font-size: 14px; color: var(--text-mid); line-height: 1.75; margin: 0;">{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Tiers -->
  <section style="background: var(--bg); padding: 80px 24px;">
    <div style="max-width: 800px; margin: 0 auto;">
      <div style="text-align: center; margin-bottom: 52px;">
        <div class="eyebrow" style="margin-bottom: 14px;">Pricing</div>
        <h2 style="font-family: var(--ff-serif); font-size: clamp(26px, 3vw, 38px); font-weight: 700; color: var(--text); margin: 0;">Membership Options</h2>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 24px;">
        {tiers.map((tier, i) => (
          <div
            class="tier-card"
            data-index={i}
            data-name={tier.name}
            data-color={tier.color}
            style={`background: var(--bg-alt); border: 1px solid var(--border); border-top: 4px solid ${tier.color}; padding: 40px 36px; transition: border-color 0.25s;`}
          >
            <h3 style="font-family: var(--ff-serif); font-size: 20px; font-weight: 700; color: var(--text); margin: 0 0 8px;">{tier.name}</h3>
            <div style={`font-family: var(--ff-serif); font-size: 50px; font-weight: 700; color: ${tier.color}; line-height: 1; margin-bottom: 4px;`}>
              {tier.priceAmount}<span style="font-size: 18px; font-weight: 400; color: var(--text-mid);">{tier.pricePeriod}</span>
            </div>
            <p style="font-family: var(--ff-sans); font-size: 14px; color: var(--text-mid); margin: 12px 0 24px;">{tier.description}</p>
            <ul style="list-style: none; padding: 0; margin: 0 0 32px; display: grid; gap: 10px;">
              {tier.benefits.map((b) => (
                <li style="display: flex; align-items: center; gap: 10px; font-family: var(--ff-sans); font-size: 14px; color: var(--text);">
                  <span style={`color: ${tier.color}; font-weight: 700;`}>✓</span> {b}
                </li>
              ))}
            </ul>
            <button
              type="button"
              class="tier-select"
              data-index={i}
              data-name={tier.name}
              data-color={tier.color}
              style={`background: transparent; color: ${tier.color}; border: 2px solid ${tier.color}; border-radius: 4px; padding: 12px 24px; font-family: var(--ff-sans); font-size: 14px; font-weight: 600; cursor: pointer; width: 100%; transition: all 0.2s;`}
            >
              Select This Plan
            </button>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Registration form -->
  <section id="reg-form" style="display: none; background: var(--bg-alt); padding: 80px 24px; border-top: 1px solid var(--border);">
    <div style="max-width: 660px; margin: 0 auto;">
      <div class="eyebrow" style="margin-bottom: 12px;">Registration</div>
      <h2 id="reg-tier-name" style="font-family: var(--ff-serif); font-size: 32px; font-weight: 700; color: var(--text); margin: 0 0 6px;"></h2>
      <p id="reg-tier-summary" style="font-family: var(--ff-sans); font-size: 15px; color: var(--text-mid); margin: 0 0 40px;"></p>

      <form id="membershipForm" style="display: grid; gap: 20px;">
        <input type="hidden" id="membershipType" name="membershipType" />

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
          <div>
            <label class="field-label" for="firstName">First Name *</label>
            <input class="field-input" type="text" id="firstName" name="firstName" required />
          </div>
          <div>
            <label class="field-label" for="lastName">Last Name *</label>
            <input class="field-input" type="text" id="lastName" name="lastName" required />
          </div>
        </div>

        <div>
          <label class="field-label" for="email">Email Address *</label>
          <input class="field-input" type="email" id="email" name="email" required />
        </div>

        <div>
          <label class="field-label" for="phone">Phone Number *</label>
          <input class="field-input" type="tel" id="phone" name="phone" required />
        </div>

        <div>
          <label class="field-label" for="experience">Paddling Experience *</label>
          <select class="field-select" id="experience" name="experience" required>
            <option value="">Select your level</option>
            <option value="none">No experience</option>
            <option value="beginner">Beginner (less than 1 year)</option>
            <option value="intermediate">Intermediate (1–3 years)</option>
            <option value="advanced">Advanced (3+ years)</option>
          </select>
        </div>

        <div>
          <label class="field-label" for="emergency">Emergency Contact Name *</label>
          <input class="field-input" type="text" id="emergency" name="emergency" required />
        </div>

        <div>
          <label class="field-label" for="emergencyPhone">Emergency Contact Phone *</label>
          <input class="field-input" type="tel" id="emergencyPhone" name="emergencyPhone" required />
        </div>

        <div>
          <label class="field-label" for="comments">Comments / Questions</label>
          <textarea class="field-textarea" id="comments" name="comments" rows="4"></textarea>
        </div>

        <label style="display: flex; align-items: flex-start; gap: 12px; cursor: pointer;">
          <input type="checkbox" id="waiver" name="waiver" required style="margin-top: 3px; accent-color: var(--lava);" />
          <span style="font-family: var(--ff-sans); font-size: 14px; color: var(--text-mid); line-height: 1.65;">
            I understand and agree to the club's safety guidelines and waiver terms. *
          </span>
        </label>

        <div id="form-message" style="display: none; padding: 16px; border-radius: 2px;"></div>

        <div style="display: flex; gap: 12px;">
          <button id="reg-submit" type="submit" style="flex: 1; background: var(--lava); color: #fff; border: none; border-radius: 4px; padding: 14px 24px; font-family: var(--ff-sans); font-size: 15px; font-weight: 600; cursor: pointer;">
            Submit Registration →
          </button>
          <button id="reg-cancel" type="button" style="background: transparent; color: var(--text-mid); border: 1px solid var(--border); border-radius: 4px; padding: 14px 20px; font-family: var(--ff-sans); font-size: 14px; cursor: pointer;">
            Cancel
          </button>
        </div>
      </form>
    </div>
  </section>

  <section id="reg-thanks" style="display: none; background: var(--bg-alt); padding: 80px 24px; text-align: center; border-top: 1px solid var(--border);">
    <div style="max-width: 480px; margin: 0 auto;">
      <div style="font-size: 52px; margin-bottom: 24px;">🌊</div>
      <h2 style="font-family: var(--ff-serif); font-size: 34px; font-weight: 700; color: var(--text); margin: 0 0 16px;">Mahalo!</h2>
      <p style="font-family: var(--ff-sans); font-size: 16px; color: var(--text-mid); line-height: 1.75; margin: 0;">
        Your registration has been submitted. We'll reach out shortly with next steps. Welcome to the ohana!
      </p>
    </div>
  </section>
</Layout>

<script>
  const tierCards = document.querySelectorAll<HTMLElement>('.tier-card');
  const tierButtons = document.querySelectorAll<HTMLButtonElement>('.tier-select');
  const regSection = document.getElementById('reg-form') as HTMLElement | null;
  const thanksSection = document.getElementById('reg-thanks') as HTMLElement | null;
  const tierNameEl = document.getElementById('reg-tier-name');
  const tierSummaryEl = document.getElementById('reg-tier-summary');
  const membershipTypeInput = document.getElementById('membershipType') as HTMLInputElement | null;
  const submitBtn = document.getElementById('reg-submit') as HTMLButtonElement | null;
  const cancelBtn = document.getElementById('reg-cancel');
  const form = document.getElementById('membershipForm') as HTMLFormElement | null;
  const messageDiv = document.getElementById('form-message') as HTMLDivElement | null;

  let selectedIndex: number | null = null;

  const updateSelection = (index: number) => {
    selectedIndex = index;
    tierCards.forEach((card, i) => {
      const color = card.dataset.color || 'var(--border)';
      card.style.borderColor = i === index ? color : 'var(--border)';
      card.style.borderTopColor = color;
    });
    tierButtons.forEach((btn, i) => {
      const color = btn.dataset.color || 'var(--lava)';
      if (i === index) {
        btn.style.background = color;
        btn.style.color = '#fff';
        btn.textContent = '✓ Selected';
      } else {
        btn.style.background = 'transparent';
        btn.style.color = color;
        btn.textContent = 'Select This Plan';
      }
    });

    const card = tierCards[index];
    const name = card?.dataset.name ?? '';
    const color = card?.dataset.color ?? 'var(--lava)';
    const priceEl = card?.querySelector('div[style*="font-size: 50px"]');
    const descEl = card?.querySelector('p');

    if (tierNameEl) tierNameEl.textContent = name;
    if (tierSummaryEl) {
      const priceText = priceEl?.textContent?.trim() ?? '';
      tierSummaryEl.textContent = `${priceText} — fill in your details and we'll reach out with next steps.`;
    }
    if (membershipTypeInput) membershipTypeInput.value = name;
    if (submitBtn) submitBtn.style.background = color;
    if (regSection) regSection.style.display = 'block';
    if (thanksSection) thanksSection.style.display = 'none';

    setTimeout(() => {
      regSection?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }, 80);
  };

  tierButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const idx = parseInt(btn.dataset.index || '0', 10);
      updateSelection(idx);
    });
  });

  cancelBtn?.addEventListener('click', () => {
    selectedIndex = null;
    if (regSection) regSection.style.display = 'none';
    tierCards.forEach((card) => {
      card.style.borderColor = 'var(--border)';
    });
    tierButtons.forEach((btn) => {
      const color = btn.dataset.color || 'var(--lava)';
      btn.style.background = 'transparent';
      btn.style.color = color;
      btn.textContent = 'Select This Plan';
    });
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form) return;

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Submitting...';
    }
    if (messageDiv) messageDiv.style.display = 'none';

    try {
      const response = await fetch('https://formsubmit.co/ajax/admin@9thislandoutrigger.com', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify({
          _subject: `New Membership Application: ${data.firstName} ${data.lastName}`,
          ...data,
        }),
      });

      if (!response.ok) throw new Error('Form submission failed');

      form.reset();
      if (regSection) regSection.style.display = 'none';
      if (thanksSection) {
        thanksSection.style.display = 'block';
        thanksSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    } catch (err) {
      if (messageDiv) {
        messageDiv.style.display = 'block';
        messageDiv.style.background = 'rgba(232,56,10,0.1)';
        messageDiv.style.color = 'var(--lava-dark)';
        messageDiv.textContent = 'Something went wrong. Please try again later.';
      }
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Submit Registration →';
      }
    }
  });
</script>
